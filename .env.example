# HVAC AI — Environment Variables
# Copy to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Anthropic (LLM Classifier) ────────────────────────────────────────────────
# Optional. Rule-based classifier fires when this is absent.
ANTHROPIC_API_KEY=sk-ant-...

# ── Dispatcher (Escalation / Safety Gate) ─────────────────────────────────────
# When an emergency or urgent safety-gate trigger fires, the dispatcher
# receives a real voice call reading the alert aloud.
# Format: E.164, e.g. +19565551234
DISPATCHER_PHONE=+1XXXXXXXXXX

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Public-facing base URL (used for webhook signature validation)
BASE_URL=https://your-domain.com

# ── Jobber (FSM) ─────────────────────────────────────────────────────────────
# Optional. MockFsmAdapter used when absent.
JOBBER_ACCESS_TOKEN=
JOBBER_REFRESH_TOKEN=
JOBBER_SUBDOMAIN=your-subdomain

# ── Ecobee (IoT / Layer 4) ─────────────────────────────────────────────────
# Optional. IoT webhook silently skipped when absent.
ECOBEE_API_KEY=
ECOBEE_SIGNATURE_SECRET=
IOT_ENABLED=false

# ── Session / Queue ───────────────────────────────────────────────────────────
# TTL in milliseconds (default: 30 minutes)
SESSION_TTL_MS=1800000

# ── Thermostat Thresholds ─────────────────────────────────────────────────────
MIN_CYCLE_HOURS=3
FILTER_HOURS=500
ANOMALY_THRESHOLD=1.5
AUX_HEAT_THRESHOLD=0.4
OVERSIZED_TONS=3.0

# ── Renewal Campaign ───────────────────────────────────────────────────────────
# Set to 'true' to simulate without sending real messages
RENEWAL_DRY_RUN=true
# Days before expiry to begin outreach (default: 30)
RENEWAL_DAYS_NOTICE=30
# Daily cap on outbound renewal messages
MAX_DAILY_OUTREACH=50

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Queue Persistence ──────────────────────────────────────────────────────────
# Directory for queue JSONL log + snapshot files (default: ./data)
QUEUE_DATA_DIR=./data
# Write snapshot every N enqueue operations (default: 50)
QUEUE_SNAPSHOT_EVERY=50
